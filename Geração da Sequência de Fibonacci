using System;
using System.Collections.Generic;

public class Program
{
    public static void Main()
    {
        var resultado = GerarFibonacci(7);

        foreach (var numero in resultado)
        {
            Console.Write(numero + " ");
        }
    }

    public static List<int> GerarFibonacci(int quantidade)
    {
        var lista = new List<int>();

        if (quantidade <= 0)
            return lista;

        lista.Add(0);

        if (quantidade == 1)
            return lista;

        lista.Add(1);

        for (int i = 2; i < quantidade; i++)
        {
            int proximo = lista[i - 1] + lista[i - 2];
            lista.Add(proximo);
        }

        return lista;
    }
}
